# Copy this file to ".env" and fill in your own values.
# Never commit your real .env — it holds secrets.

# --- Twilio (from console.twilio.com) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_NUMBER=+15125550148          # your Twilio number, E.164 format

# --- Where missed calls should ring first ---
OWNER_CELL=+15125551234             # your real phone, E.164 format

# --- How your texts read ---
BUSINESS_NAME=Rapid Response Plumbing
OWNER_NAME=Mike
BOOKING_LINK=https://calendly.com/rapidplumb/quote

# --- Behavior ---
RING_SECONDS=18                     # rings before a call counts as "missed"
SEND_FOLLOWUPS=true                 # auto-send the Day-1/3/7 sequence
PORT=5000
